{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BareMetalHost Chart Values",
  "type": "object",
  "required": ["nodeName", "driver"],
  "properties": {
    "nodeName":         {"type": "string"},
    "nodeUuid":         {"type": "string"},
    "parentNode":       {"type": "string"},
    "driver":           {"type": "string", "enum": ["ipmi", "redfish", "fake-hardware"]},
    "driver_info":      {"type": ["object", "null"]},
    "nodeNamespace":    {"type": "string"},
    "ports":            {"type": ["array", "null"]},
    "enableInspection": {"type": "boolean", "default": false},
    "image":            {"type": ["object", "null"]},
    "configDrive":      {"type": ["object", "null"]},
    "online":           {"type": "boolean"},
    "maintenance":      {"type": "boolean", "default": false},
    "detached":         {"type": "boolean", "default": false},
    "networkData":      {"type": ["object", "null"]},
    "cleanSteps":       {"type": ["array", "null"], "description": "Ironic clean steps to run while manageable. Each item: interface, step, args."},
    "undeploy":         {"type": "boolean", "default": false, "description": "When true, drives the blade from `active` back to `available` via transition-undeploy. Hold-at-available signal."},
    "undeployMode":     {"type": "string",  "enum": ["full", "none"], "default": "full", "description": "Ironic cleanup pass between deleted and available. full=standard clean_steps, none=skip (fast, dirty)."},
    "configurationRef": {"type": "object"}
  }
}
