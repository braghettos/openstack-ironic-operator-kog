{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KubernetesCluster Chart Values",
  "type": "object",
  "required": ["clusterName", "k8sVersion"],
  "properties": {
    "clusterName": {
      "type": "string",
      "description": "Logical cluster name. Used as a prefix for rendered BaremetalLifecycle CR names."
    },
    "k8sVersion": {
      "type": "string",
      "description": "kubelet/kubeadm package version, e.g. v1.31.4."
    },
    "cni": {
      "type": ["object", "null"],
      "properties": {
        "install": {"type": "string"},
        "manifestUrl": {"type": "string"}
      }
    },
    "network": {
      "type": ["object", "null"],
      "properties": {
        "podCIDR": {"type": "string"},
        "serviceCIDR": {"type": "string"},
        "managementApiReachability": {
          "type": ["string", "null"],
          "enum": [null, "kube-vip", "metallb", "external-lb", "nodeport-dns"],
          "description": "How the management cluster's API is reached from bare-metal blades. Pure documentation hint today; future milestones may branch on this. See docs/USER-GUIDE.md 'Cluster ingress'."
        }
      }
    },
    "image": {
      "type": "object",
      "properties": {
        "source":   {"type": ["string", "null"]},
        "checksum": {"type": ["string", "null"]}
      }
    },
    "lifecycleNamespace": {"type": ["string", "null"]},
    "configurationRef": {
      "type": "object",
      "properties": {
        "name":      {"type": "string"},
        "namespace": {"type": "string"}
      }
    },
    "ironicApiUrl":     {"type": "string"},
    "ironicApiVersion": {"type": "string"},
    "ironicAuth": {
      "type": ["object", "null"],
      "description": "Keystone credentials baked into the CP cloud-init so publish-join.sh can PATCH Ironic node.extra directly.",
      "properties": {
        "authUrl":    {"type": ["string", "null"]},
        "ironicUrl":  {"type": ["string", "null"]},
        "username":   {"type": ["string", "null"]},
        "password":   {"type": ["string", "null"]},
        "userDomain": {"type": ["string", "null"]}
      }
    },
    "managementCluster": {
      "type": "object",
      "description": "Endpoint + auth used by the CP cloud-init to kubectl-patch its own Node CR's spec.extra.kubeadm_join.",
      "properties": {
        "apiUrl":                  {"type": ["string", "null"]},
        "caBundle":                {"type": ["string", "null"]},
        "serviceAccountName":      {"type": ["string", "null"]},
        "serviceAccountNamespace": {"type": ["string", "null"]}
      }
    },
    "controlPlane": {
      "type": "object",
      "properties": {
        "endpoint": {
          "type": ["string", "null"],
          "description": "Stable address kubeadm advertises as the cluster apiserver. Empty for single-CP; required for HA (must point at a load-balanced VIP)."
        },
        "etcd": {
          "type": ["object", "null"],
          "description": "v0.11.0: external etcd config for HA clusters. Ignored when nodes[] has <=1 entry (single-CP uses kubeadm stacked etcd).",
          "properties": {
            "aptPackage":            {"type": ["string", "null"]},
            "snapshotImage":         {"type": ["string", "null"]},
            "snapshotSchedule":      {"type": ["string", "null"]},
            "snapshotRetentionDays": {"type": ["integer", "null"]}
          }
        },
        "nodes": {
          "type": ["array", "null"],
          "description": "Preferred HA shape. Index 0 = bootstrap CP. 1, 3, or 5 entries.",
          "items": {
            "type": "object",
            "properties": {
              "nodeName":    {"type": ["string", "null"]},
              "nodeUuid":    {"type": ["string", "null"]},
              "parentNode":  {"type": ["string", "null"]},
              "oobIp":       {"type": ["string", "null"], "description": "v0.11.0: OOB-network IP for this CP. REQUIRED for HA (cpNodes > 1) so etcd peer URLs land on the stable management NIC."},
              "driver":      {"type": ["string", "null"]},
              "driver_info": {"type": ["object", "null"]},
              "ports":       {"type": ["array", "null"]}
            }
          }
        },
        "node": {
          "type": "object",
          "description": "Legacy single-CP shape. Ignored when controlPlane.nodes[] is non-empty.",
          "properties": {
            "nodeName":    {"type": ["string", "null"]},
            "nodeUuid":    {"type": ["string", "null"]},
            "parentNode":  {"type": ["string", "null"]},
            "driver":      {"type": ["string", "null"]},
            "driver_info": {"type": ["object", "null"]},
            "ports":       {"type": ["array", "null"]}
          }
        },
        "upgrade": {
          "type": ["object", "null"],
          "description": "Milestone 5a day-2 lever for k8s upgrade by-reimage. Pin one CP nodeName at a time to drive it through undeploy -> redeploy.",
          "properties": {
            "targetNode": {"type": ["string", "null"]}
          }
        },
        "recovery": {
          "type": ["object", "null"],
          "description": "Milestone 5c day-2 lever for failed CP recovery.",
          "properties": {
            "failedNodes": {
              "type": ["array", "null"],
              "items": {
                "type": "object",
                "properties": {
                  "nodeName":     {"type": ["string", "null"]},
                  "nodeUuid":     {"type": ["string", "null"]},
                  "parentNode":   {"type": ["string", "null"]},
                  "driver":       {"type": ["string", "null"]},
                  "driver_info":  {"type": ["object", "null"]},
                  "ports":        {"type": ["array", "null"]},
                  "undeployMode": {"type": ["string", "null"], "enum": [null, "full", "none"]}
                }
              }
            }
          }
        }
      }
    },
    "workers": {
      "type": ["object", "null"],
      "properties": {
        "drainTimeout": {
          "type": ["string", "null"],
          "description": "Passed to `kubectl drain --timeout=` in the Milestone 5b drain Jobs. Defaults to 5m."
        },
        "nodes": {
          "type": ["array", "null"],
          "items": {
            "type": "object",
            "properties": {
              "nodeName":    {"type": ["string", "null"]},
              "nodeUuid":    {"type": ["string", "null"]},
              "parentNode":  {"type": ["string", "null"]},
              "driver":      {"type": ["string", "null"]},
              "driver_info": {"type": ["object", "null"]},
              "ports":       {"type": ["array", "null"]}
            }
          }
        },
        "removed": {
          "type": ["array", "null"],
          "description": "Workers being drained + undeployed. Move an entry here from `nodes` to start the removal flow.",
          "items": {
            "type": "object",
            "properties": {
              "nodeName":     {"type": ["string", "null"]},
              "nodeUuid":     {"type": ["string", "null"]},
              "parentNode":   {"type": ["string", "null"]},
              "driver":       {"type": ["string", "null"]},
              "driver_info":  {"type": ["object", "null"]},
              "ports":        {"type": ["array", "null"]},
              "undeployMode": {
                "type": ["string", "null"],
                "enum": [null, "full", "none"],
                "description": "Ironic cleanup pass between deleted and available. full=standard clean_steps, none=skip (fast, dirty). Requires baremetal:node:disable_cleaning policy for none."
              }
            }
          }
        }
      }
    }
  }
}
